# ── Phantom MCP ──────────────────────────────────────────────────────────────
# From portal.phantom.app → New App → Embedded Wallet → App ID
PHANTOM_APP_ID=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
TEST_NETWORK=devnet

# A second devnet address to receive test transfers.
# Get one with: solana-keygen new --no-bip39-passphrase -o /tmp/test-recipient.json
# Then: solana address -k /tmp/test-recipient.json
TEST_RECIPIENT_ADDRESS=

# ── Ethereum (optional — for multi-chain dim 7 verification) ──────────────────
ETH_RPC_URL=

# ── Coinbase AgentKit ─────────────────────────────────────────────────────────
# Step 1: Create account at https://portal.cdp.coinbase.com
# Step 2: API Keys → Create API Key → copy both values below
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Step 3: Create a Wallet Secret in the Portal (NOT a locally-generated hex string).
#   Portal → Wallet Secrets → Create Wallet Secret → copy the base64 value shown.
#   The SDK expects a base64-encoded EC P-256 PKCS#8 private key generated by Coinbase.
CDP_WALLET_SECRET=

# Network (base-sepolia is the default testnet — no changes needed)
NETWORK_ID=base-sepolia

# Wallet address — set this after the first run to reuse the same wallet across runs.
# On first run, the adapter prints: "New wallet created: 0x..."  — copy that address here.
# Without this, a new wallet is created on every run and funds are lost.
COINBASE_WALLET_ADDRESS=

# ── HeyElsa x402 API ─────────────────────────────────────────────────────────
# The private key wallet pays x402 micropayments on Base mainnet (real USDC).
# Estimated cost: ~$0.20 USDC per full test run (13 API calls).
# Format: 0x followed by 64 hex characters.
HEYELSA_PRIVATE_KEY=d0210022f12d72ce4c3f505aa7ea930c7879e9efc4eb9c9a7c1e1b432fea28b1

# The wallet address to use for portfolio/balance queries.
# Optional — derived automatically from HEYELSA_PRIVATE_KEY if not set.
HEYELSA_WALLET_ADDRESS=0x8617dD6b2612377f8b400Cc6A0375154eF72b6fA

# Base mainnet RPC URL (optional — defaults to https://mainnet.base.org).
# Use Alchemy/Infura for better reliability during testing.
BASE_RPC_URL=https://mainnet.base.org
